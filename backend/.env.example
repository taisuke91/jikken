# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# モデル名（環境に合わせて変更可）
GEMINI_MODEL=gemini-2.5-flash-lite

# マイコンへ送る場合（例: macOS CH340 は /dev/cu.usbserial-*、公式Arduinoは /dev/cu.usbmodem*）
# 未設定ならシリアル送信はスキップ
# SERIAL_PORT=/dev/cu.usbserial-1410
# SERIAL_BAUD=115200
# 初心者向け: FLAME 0〜3 のように状態だけ送る（Arduinoサンプルと一致）
# SERIAL_SIMPLE=1
